{
  "schema_version": 1,
  "id": "chatgpt-web",
  "name": "ChatGPT Web",
  "version": "0.1.0",
  "origin": "official",
  "description": "Official AssetIWeave harvester template for ChatGPT web conversations.",
  "entrypoint": [
    "scripts/harvest.js"
  ],
  "capabilities": [
    "browser_cookie_auth",
    "conversation_export",
    "normalized_sessions"
  ],
  "output": {
    "raw_dir": "output/raw",
    "normalized_dir": "output/normalized",
    "sessions_file": "sessions.json"
  },
  "adapter": {
    "manifest": "conversation-adapter.json"
  },
  "source": {
    "id": "chatgpt-web-export",
    "kind": "directory",
    "name": "ChatGPT Web Export"
  },
  "update": {
    "channel": "official"
  }
}
