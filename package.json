{
  "name": "assetiweave",
  "private": true,
  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "artifacts:check": "node scripts/build-artifacts.mjs check",
    "artifacts:clean": "node scripts/build-artifacts.mjs clean",
    "artifacts:guard": "node scripts/build-artifacts.mjs guard",
    "artifacts:test": "node --test scripts/build-artifacts.test.mjs",
    "prebuild": "pnpm artifacts:guard",
    "dev": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 1420",
    "build": "tsc -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "postbuild": "pnpm artifacts:check",
    "bundle:cli": "node scripts/bundle-cli.js",
    "preengine:build": "pnpm artifacts:guard",
    "engine:build": "cargo build -p assetiweave --bin assetiweave-engine",
    "postengine:build": "pnpm artifacts:check",
    "cli:contract": "pnpm engine:build && node scripts/generate-cli-contract.js",
    "precli:build": "pnpm artifacts:guard",
    "cli:build": "node scripts/build-cli.js",
    "postcli:build": "pnpm artifacts:check",
    "cli:install": "node scripts/install.js",
    "cli:release-audit": "node scripts/release-audit.js",
    "cli:run": "node scripts/run.js",
    "precli:test": "pnpm artifacts:guard",
    "cli:test": "GOCACHE=$PWD/target/go-build go test -C cli ./...",
    "postcli:test": "pnpm artifacts:check",
    "cli:test:e2e": "go test -C cli -tags=e2e ./tests/cli_e2e",
    "conversation-adapters:check": "node scripts/conversation-adapter-packages.mjs check",
    "conversation-adapters:build": "node scripts/conversation-adapter-packages.mjs build",
    "preview": "vite preview --config frontend/vite.config.ts --host 127.0.0.1",
    "tauri": "tauri",
    "pretauri:dev": "pnpm artifacts:guard",
    "tauri:dev": "tauri dev",
    "test": "vitest run --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.511.0",
    "mermaid": "^11.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "undici": "7.28.0"
    }
  }
}
