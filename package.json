{
  "name": "assetiweave",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 1420",
    "build": "tsc -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "engine:build": "cargo build -p assetiweave --bin assetiweave-engine",
    "cli:contract": "pnpm engine:build && node scripts/generate-cli-contract.js",
    "cli:build": "node scripts/build-cli.js",
    "cli:install": "node scripts/install.js",
    "cli:release-audit": "node scripts/release-audit.js",
    "cli:run": "node scripts/run.js",
    "cli:test": "GOCACHE=$PWD/target/go-build go test -C cli ./...",
    "cli:test:e2e": "go test -C cli -tags=e2e ./tests/cli_e2e",
    "preview": "vite preview --config frontend/vite.config.ts --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "test": "vitest run --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "mermaid": "^11.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
